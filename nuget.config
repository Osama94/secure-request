<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      <clear /> removes all inherited sources (including corporate feeds from the global
      NuGet config) so only nuget.org is used for all packages under D:\MyPackages\.
    -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
