{
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },

  "SecureRequest": {
    "Enabled": true,
    "EnableBodyEncryption": true,
    "EnableHmacSigning": true,
    "TimestampToleranceSeconds": 300,
    "NonceCacheTtlSeconds": 700,
    "SecuredMethods": [ "POST", "PUT", "PATCH" ],
    "ExcludedPaths": [
      "/api/secure/public-key",
      "/swagger",
      "/health"
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "SecureRequest": "Warning"
    }
  },

  "AllowedHosts": "*"
}
